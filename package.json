{
  "name": "tech-news-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "remotion:preview": "remotion preview src/index.ts --browser-executable=\"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\"",
    "remotion:render": "remotion render src/index.ts TechNewsEpisode data/videos/latest-tech-news.mp4 --browser-executable=\"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\"",
    "remotion:still": "remotion still src/index.ts TechNewsEpisode data/production/latest-preview.png --frame=60 --browser-executable=\"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\"",
    "news:aggregate": "node scripts/run_news_aggregator.mjs",
    "news:aggregate:daily": "node scripts/run_news_aggregator.mjs --profile daily_collect",
    "news:aggregate:select": "node scripts/run_news_aggregator.mjs --profile five_day_supplement",
    "news:aggregate:assets": "node scripts/run_news_aggregator.mjs --profile asset_research",
    "news:daily": "node scripts/daily_news_job.mjs",
    "news:select": "node scripts/five_day_selection_job.mjs",
    "capture:daily-assets": "node scripts/capture_daily_assets.mjs",
    "build:episode": "node scripts/build_episode_from_srt.mjs",
    "test": "node --test scripts/*.test.mjs",
    "validate:timeline": "node scripts/validate_timeline.mjs",
    "validate:timeline:video": "node scripts/validate_timeline.mjs data/videos/latest-tech-news.mp4"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "playwright": "^1.60.0",
    "typescript": "^5.4.0"
  }
}
